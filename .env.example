# =============================================================================
# EMAIL SERVICE CONFIGURATION - EXAMPLE FILE
# =============================================================================
# Copy this file to .env and update the values according to your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=email_service
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_HTTP_PORT=8080
SERVER_GRPC_PORT=9090
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=30s

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# RABBITMQ CONFIGURATION
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_DEFAULT_PROVIDER=smtp
EMAIL_FROM=noreply@example.com
EMAIL_REPLY_TO=

# SMTP Configuration
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your_email@gmail.com
EMAIL_SMTP_PASSWORD=your_app_password
EMAIL_SMTP_USE_SSL=false

# AWS SES Configuration
EMAIL_AWS_REGION=us-east-1
EMAIL_AWS_ACCESS_KEY=your_aws_access_key
EMAIL_AWS_SECRET_KEY=your_aws_secret_key

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
AUTH_API_KEY_HEADER_NAME=X-API-Key
AUTH_ADMIN_API_TOKEN=change_this_in_production

# =============================================================================
# AWS CLOUDWATCH CONFIGURATION
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_LOG_GROUP=/email-service/production

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_ENVIRONMENT=development
APP_LOG_LEVEL=info
APP_SERVICE_NAME=email-service

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
STORAGE_PROVIDER=local
STORAGE_BASE_URL=
STORAGE_MAX_SIZE=10485760
STORAGE_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# Local Storage Configuration
STORAGE_LOCAL_PATH=./storage/attachments
STORAGE_LOCAL_BASE_URL=

# S3 Storage Configuration
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=your-bucket-name
STORAGE_S3_ACCESS_KEY=your_s3_access_key
STORAGE_S3_SECRET_KEY=your_s3_secret_key
STORAGE_S3_BASE_URL=
STORAGE_S3_PREFIX=

# Firebase Storage Configuration
STORAGE_FIREBASE_PROJECT_ID=your-firebase-project-id
STORAGE_FIREBASE_BUCKET=your-firebase-bucket
STORAGE_FIREBASE_CRED_FILE=
STORAGE_FIREBASE_SERVICE_ACCOUNT_JSON=
STORAGE_FIREBASE_CREDENTIALS_FILE=
STORAGE_FIREBASE_STORAGE_PATH=email-attachments

# =============================================================================
# WEB UI CONFIGURATION
# =============================================================================
WEBUI_ENABLED=true
WEBUI_USERNAME=admin
WEBUI_PASSWORD=admin123
WEBUI_SESSION_SECRET=your-session-secret-key-change-this-in-production
WEBUI_SESSION_DURATION=480
